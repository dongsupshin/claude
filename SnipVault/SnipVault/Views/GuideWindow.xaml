<Window x:Class="SnipVault.Views.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SnipVault — Quick Start Guide"
        Width="640" Height="560" MinWidth="480" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#111827" Foreground="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="36,20">
            <Grid>
                <!-- Page 1: Welcome -->
                <StackPanel x:Name="Page1">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="Welcome to SnipVault!" FontSize="26" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Your smart text and code snippet manager"
                               FontSize="15" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,4,0,0"/>

                    <Border Background="#1E1E2E" CornerRadius="12" Padding="24,18" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="SnipVault helps you:" Foreground="#E5E7EB" FontSize="15"
                                       FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Save frequently used text snippets and code blocks
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Organize with categories and language tags
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Quickly search, copy, and paste with one click
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Pin your most-used snippets to the top
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Import/export via JSON for backup and sharing
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 2: Creating Snippets -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <TextBlock Text="✏️" FontSize="42" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="Creating &amp; Editing Snippets" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                    <Border Background="#1E1E2E" CornerRadius="12" Padding="24,18" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,5">
                                <Run Foreground="#A78BFA" FontWeight="Bold">1.</Run>  Click the "+ New" button in the left panel to create a new snippet.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,5">
                                <Run Foreground="#A78BFA" FontWeight="Bold">2.</Run>  Enter a title, choose a category and language, then type or paste your content.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,5">
                                <Run Foreground="#A78BFA" FontWeight="Bold">3.</Run>  Click "Save" to save your snippet. It appears in the list instantly.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,5">
                                <Run Foreground="#A78BFA" FontWeight="Bold">4.</Run>  Click any snippet in the list to view and edit it in the right panel.
                            </TextBlock>
                            <Border Background="#1B2838" CornerRadius="8" Padding="14,10" Margin="0,10,0,0">
                                <TextBlock Foreground="#60A5FA" FontSize="13" TextWrapping="Wrap">
                                    💡 Tip: You can type a new category name directly — it will be saved automatically!
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 3: Organization & Search -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <TextBlock Text="🔍" FontSize="42" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    <TextBlock Text="Search &amp; Organization" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                    <Border Background="#1E1E2E" CornerRadius="12" Padding="24,18" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                🔍  Use the search box to find snippets by title, content, category, or language.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                📂  Filter by category using the dropdown menu.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ★  Click the star button to show only your favorite snippets.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                📌  Pin important snippets so they always appear at the top of the list.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                📋  Hit the green "Copy" button to copy a snippet's content to your clipboard.
                            </TextBlock>

                            <Border Background="#1B2838" CornerRadius="8" Padding="14,10" Margin="0,10,0,0">
                                <TextBlock Foreground="#60A5FA" FontSize="13" TextWrapping="Wrap">
                                    💡 Use Import/Export in the bottom bar to back up your snippets as JSON, or share them between machines!
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="You're all set!" Foreground="#10B981" FontSize="16"
                               FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,20,0,6"/>
                    <TextBlock Foreground="#9CA3AF" FontSize="14" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center">
                        Click "Get Started" to begin. Reopen this guide anytime from the bottom bar.
                    </TextBlock>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1" Background="#0F172A" Padding="30,14">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#6366F1" Margin="4,0"/>
                    <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#374151" Margin="4,0"/>
                    <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#374151" Margin="4,0"/>
                </StackPanel>

                <Button x:Name="BackButton" HorizontalAlignment="Left" Click="OnBack"
                        Cursor="Hand" Visibility="Collapsed" Padding="20,10">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#374151" CornerRadius="8" Padding="20,10" x:Name="bd" Cursor="Hand">
                                <TextBlock Text="← Back" Foreground="#D1D5DB" FontSize="14"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="NextButton" HorizontalAlignment="Right" Click="OnNext" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#6366F1" CornerRadius="8" Padding="24,10" x:Name="bd" Cursor="Hand">
                                <TextBlock x:Name="NextText" Text="Next →" Foreground="White"
                                           FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#818CF8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
