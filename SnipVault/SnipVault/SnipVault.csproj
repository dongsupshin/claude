<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <AssemblyName>SnipVault</AssemblyName>
    <RootNamespace>SnipVault</RootNamespace>
    <Version>1.0.0</Version>
    <Authors>SnipVault Team</Authors>
    <Description>Smart Snippet Manager — Save, organize, and quickly paste your text and code snippets</Description>
    <Copyright>Copyright © 2026 SnipVault</Copyright>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

</Project>
