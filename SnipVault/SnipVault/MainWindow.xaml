<Window x:Class="SnipVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SnipVault.Converters"
        Title="SnipVault — Snippet Manager"
        Width="960" Height="640" MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="#111827" Foreground="White">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:FavoriteToColorConverter x:Key="FavToColor"/>
        <conv:PinToColorConverter x:Key="PinToColor"/>
        <conv:DateTimeToRelativeConverter x:Key="DateToRel"/>
        <conv:StringNotEmptyToVisibility x:Key="StrToVis"/>

        <!-- Dark TextBox Style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1E1E2E"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pill Button -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ LEFT PANEL: Snippet List ═══ -->
        <Border Grid.Column="0" Grid.Row="0" Background="#0F172A" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="4,4,4,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="22" VerticalAlignment="Center"/>
                        <TextBlock Text=" SnipVault" FontSize="20" FontWeight="Bold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Your Snippet Manager" Foreground="#6B7280" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Search Box -->
                <TextBox Grid.Row="1" Style="{StaticResource DarkTextBox}"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Tag="🔍 Search snippets..." Margin="0,0,0,8"/>

                <!-- Filter Row -->
                <Grid Grid.Row="2" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}" Margin="0,0,6,0"/>

                    <ToggleButton Grid.Column="1" IsChecked="{Binding FavoritesOnly}"
                                  Content="★" FontSize="18" Width="36" Height="36"
                                  ToolTip="Favorites only" Cursor="Hand"
                                  Background="#1E1E2E" Foreground="#FBBF24" BorderBrush="#374151"/>

                    <Button Grid.Column="2" Command="{Binding NewSnippetCommand}"
                            Style="{StaticResource PillBtn}" Background="#6366F1"
                            Padding="12,8" Margin="6,0,0,0">
                        <TextBlock Text="+ New" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                    </Button>
                </Grid>

                <!-- Snippet List -->
                <ListBox Grid.Row="3" Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding FilteredSnippets}"
                         SelectedItem="{Binding SelectedSnippet}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="#1E1E2E" CornerRadius="8"
                                                Padding="12,10" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1E1B4B"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#6366F1"/>
                                                <Setter TargetName="bd" Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#1F2937"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Title row -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <TextBlock Text="📌" FontSize="12" Margin="0,0,4,0"
                                               Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}"/>
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14"
                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text=" ★" Foreground="#FBBF24" FontSize="13"
                                               Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                                <!-- Meta row -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                    <Border Background="#2D2B55" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Language}" Foreground="#A78BFA" FontSize="10"/>
                                    </Border>
                                    <Border Background="#1B2838" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                        <TextBlock Text="{Binding Category}" Foreground="#60A5FA" FontSize="10"/>
                                    </Border>
                                    <TextBlock Text="{Binding ModifiedAt, Converter={StaticResource DateToRel}}"
                                               Foreground="#6B7280" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ═══ RIGHT PANEL: Editor / Viewer ═══ -->
        <Border Grid.Column="1" Grid.Row="0" Padding="24,16">
            <Grid>
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a snippet or create a new one"
                               Foreground="#6B7280" FontSize="15" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <Button Command="{Binding NewSnippetCommand}" Style="{StaticResource PillBtn}"
                            Background="#6366F1" Padding="20,10" HorizontalAlignment="Center" Margin="0,16,0,0">
                        <TextBlock Text="+ New Snippet" Foreground="White" FontSize="14"/>
                    </Button>
                </StackPanel>

                <!-- Editor Panel -->
                <Grid Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title + Action Buttons -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBox Style="{StaticResource DarkTextBox}" FontSize="18" FontWeight="SemiBold"
                                 Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,200,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Command="{Binding ToggleFavoriteCommand}" Style="{StaticResource PillBtn}"
                                    Background="Transparent" Padding="8" ToolTip="Toggle favorite">
                                <TextBlock Text="★" FontSize="20"
                                           Foreground="{Binding EditIsFavorite, Converter={StaticResource FavToColor}}"/>
                            </Button>
                            <Button Command="{Binding TogglePinCommand}" Style="{StaticResource PillBtn}"
                                    Background="Transparent" Padding="8" ToolTip="Toggle pin">
                                <TextBlock Text="📌" FontSize="16"/>
                            </Button>
                            <Button Command="{Binding CopyToClipboardCommand}" Style="{StaticResource PillBtn}"
                                    Background="#10B981" Padding="14,8" Margin="4,0" ToolTip="Copy to clipboard">
                                <TextBlock Text="📋 Copy" Foreground="White" FontSize="13"/>
                            </Button>
                            <Button Command="{Binding DeleteSnippetCommand}" Style="{StaticResource PillBtn}"
                                    Background="#EF4444" Padding="10,8" ToolTip="Delete snippet">
                                <TextBlock Text="🗑" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Category + Language -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Category:" Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Style="{StaticResource DarkTextBox}" Width="160"
                                 Text="{Binding EditCategory, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Language:" Foreground="#9CA3AF" FontSize="12" VerticalAlignment="Center" Margin="16,0,6,0"/>
                        <ComboBox Style="{StaticResource DarkCombo}" Width="140"
                                  ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding EditLanguage}"/>
                    </StackPanel>

                    <!-- Content Editor -->
                    <TextBox Grid.Row="2" Style="{StaticResource DarkTextBox}"
                             Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" AcceptsTab="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="13"/>

                    <!-- Save / Cancel -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Command="{Binding SaveSnippetCommand}" Style="{StaticResource PillBtn}"
                                Background="#6366F1" Padding="20,10" Margin="0,0,8,0">
                            <TextBlock Text="💾 Save" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2" Background="#0F172A" Padding="16,8">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#9CA3AF" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding ImportCommand}" Style="{StaticResource PillBtn}"
                            Background="Transparent" Padding="8,4" ToolTip="Import from clipboard JSON">
                        <TextBlock Text="📥 Import" Foreground="#9CA3AF" FontSize="11"/>
                    </Button>
                    <Button Command="{Binding ExportCommand}" Style="{StaticResource PillBtn}"
                            Background="Transparent" Padding="8,4" ToolTip="Export to clipboard JSON">
                        <TextBlock Text="📤 Export" Foreground="#9CA3AF" FontSize="11"/>
                    </Button>
                    <Button Command="{Binding ShowGuideCommand}" Style="{StaticResource PillBtn}"
                            Background="Transparent" Padding="8,4">
                        <TextBlock Text="📖 Guide" Foreground="#9CA3AF" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
