<UserControl x:Class="FocusGuard.Views.TimerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:FocusGuard.ViewModels"
             xmlns:conv="clr-namespace:FocusGuard.Converters"
             d:DataContext="{d:DesignInstance vm:TimerViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Phase Indicator -->
        <Border Grid.Row="0" Margin="0,0,0,20" Padding="16,10"
                CornerRadius="12" HorizontalAlignment="Center">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#2D1F4B"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBreak}" Value="True">
                            <Setter Property="Background" Value="#1B3A2D"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding PhaseText}" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#A78BFA"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBreak}" Value="True">
                                    <Setter Property="Foreground" Value="#6EE7B7"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="  •  " Foreground="#666" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StatusText}" Foreground="#999" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Timer Display -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Circular Progress + Time -->
            <Grid Grid.Row="0" Width="280" Height="280" HorizontalAlignment="Center">
                <!-- Background Circle -->
                <Ellipse Width="280" Height="280" Stroke="#2A2A3E" StrokeThickness="8" Fill="Transparent"/>

                <!-- Progress Arc (simplified as a progress bar below the circle for WPF compatibility) -->
                <Ellipse Width="280" Height="280" StrokeThickness="8" Fill="Transparent"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.Stroke>
                        <SolidColorBrush x:Name="ProgressBrush" Color="#6366F1"/>
                    </Ellipse.Stroke>
                    <Ellipse.StrokeDashArray>
                        <DoubleCollection>
                            <!-- Will be updated via code-behind for arc effect -->
                        </DoubleCollection>
                    </Ellipse.StrokeDashArray>
                </Ellipse>

                <!-- Time Display -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding TimeDisplay}" FontSize="64" FontWeight="Light"
                               Foreground="White" HorizontalAlignment="Center"
                               FontFamily="Segoe UI"/>
                    <TextBlock FontSize="13" Foreground="#888" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Session {0}  •  {1} completed">
                                <Binding Path="CurrentSessionNumber"/>
                                <Binding Path="CompletedSessions"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Progress Bar (linear fallback) -->
            <ProgressBar Grid.Row="1" Value="{Binding Progress}" Minimum="0" Maximum="1"
                         Height="6" Margin="40,20,40,0" Foreground="#6366F1" Background="#2A2A3E"
                         BorderThickness="0"/>

            <!-- Control Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <!-- Start Button -->
                <Button Command="{Binding StartCommand}" Width="56" Height="56" Margin="8,0"
                        ToolTip="Start" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#6366F1" CornerRadius="28"
                                    x:Name="border" Cursor="Hand">
                                <Path Data="M18,4 L18,28 L30,16 Z" Fill="White" Stretch="Uniform"
                                      Width="20" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#818CF8"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Pause Button -->
                <Button Command="{Binding PauseCommand}" Width="56" Height="56" Margin="8,0"
                        ToolTip="Pause" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#4B5563" CornerRadius="28"
                                    x:Name="border" Cursor="Hand">
                                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20">
                                    <Rectangle Width="5" Height="18" Fill="White" HorizontalAlignment="Left" RadiusX="1" RadiusY="1"/>
                                    <Rectangle Width="5" Height="18" Fill="White" HorizontalAlignment="Right" RadiusX="1" RadiusY="1"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#6B7280"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Reset Button -->
                <Button Command="{Binding ResetCommand}" Width="44" Height="44" Margin="8,0"
                        ToolTip="Reset" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#374151" CornerRadius="22"
                                    x:Name="border" Cursor="Hand">
                                <TextBlock Text="↺" FontSize="22" Foreground="#D1D5DB"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Skip Button -->
                <Button Command="{Binding SkipCommand}" Width="44" Height="44" Margin="8,0"
                        ToolTip="Skip to next phase" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#374151" CornerRadius="22"
                                    x:Name="border" Cursor="Hand">
                                <TextBlock Text="⏭" FontSize="18" Foreground="#D1D5DB"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Eye Care Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#DD111827" CornerRadius="16"
                Visibility="{Binding IsEyeCareActive, Converter={StaticResource BoolToVis}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="👁" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="Eye Care Break" FontSize="28" FontWeight="SemiBold"
                           Foreground="#60A5FA" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Look at something 20 feet (~6m) away" FontSize="16"
                           Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="{Binding EyeCareTimeDisplay}" FontSize="48" FontWeight="Light"
                           Foreground="White" HorizontalAlignment="Center" Margin="0,20,0,0"/>
                <Button Command="{Binding DismissEyeCareCommand}" Content="Dismiss"
                        Margin="0,20,0,0" Padding="24,10" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#374151" CornerRadius="8" Padding="24,10"
                                    x:Name="border" Cursor="Hand">
                                <TextBlock Text="Dismiss" Foreground="#D1D5DB" FontSize="14"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
