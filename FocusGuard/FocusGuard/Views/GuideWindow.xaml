<Window x:Class="FocusGuard.Views.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FocusGuard — Quick Start Guide"
        Width="680" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinWidth="500" MinHeight="400"
        Background="#111827"
        Foreground="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Pages Container with ScrollViewer -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="40,24">

            <Grid>
                <!-- Page 1: Welcome -->
                <StackPanel x:Name="Page1">
                    <TextBlock Text="🛡" FontSize="48" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="Welcome to FocusGuard!" FontSize="26" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Your personal focus timer and eye care assistant"
                               FontSize="15" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,6,0,0"/>

                    <Border Background="#1E1E2E" CornerRadius="12" Padding="24,18" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="FocusGuard helps you:" Foreground="#E5E7EB" FontSize="15"
                                       FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Stay focused with the Pomodoro Technique (timed work sessions with breaks)
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Protect your eyes with the 20-20-20 Rule (automatic reminders)
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Track your productivity with detailed statistics and charts
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                ✅  Customize everything to match your workflow
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 2: Timer Guide -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <TextBlock Text="⏱" FontSize="42" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="The Focus Timer" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                    <Border Background="#1E1E2E" CornerRadius="12" Padding="24,18" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="How the Pomodoro Timer Works:" Foreground="#A78BFA"
                                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                1️⃣  Click the ▶ Play button to start a 25-minute focus session.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                2️⃣  Focus on your work until the timer rings. A short break (5 min) starts automatically.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                3️⃣  After 4 sessions, you get a longer break (15 min) to recharge.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,4">
                                4️⃣  Use ⏸ Pause anytime, or ↺ Reset to start over.
                            </TextBlock>

                            <Border Background="#1B2838" CornerRadius="8" Padding="14,10" Margin="0,10,0,0">
                                <TextBlock Foreground="#60A5FA" FontSize="13" TextWrapping="Wrap">
                                    💡 Tip: You can customize all durations in Settings. Try shorter sessions (15 min) if you're just starting out!
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 3: Eye Care Guide -->
                <StackPanel x:Name="Page3" Visibility="Collapsed">
                    <TextBlock Text="👁" FontSize="42" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="Eye Care Protection" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                    <Border Background="#1E1E2E" CornerRadius="12" Padding="24,18" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="The 20-20-20 Rule:" Foreground="#10B981"
                                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,8">
                                Every 20 minutes, look at something 20 feet (~6 meters) away for at least 20 seconds. This simple habit significantly reduces digital eye strain!
                            </TextBlock>

                            <TextBlock Text="How it works in FocusGuard:" Foreground="#A78BFA"
                                       FontSize="14" FontWeight="SemiBold" Margin="0,10,0,8"/>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,3">
                                🔔  A gentle overlay reminder appears every 20 minutes during focus sessions.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,3">
                                ⏳  A countdown shows how long to look away — only 20 seconds!
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,3">
                                ❌  You can dismiss early if needed, but we recommend following through.
                            </TextBlock>

                            <Border Background="#1B2838" CornerRadius="8" Padding="14,10" Margin="0,10,0,0">
                                <TextBlock Foreground="#60A5FA" FontSize="13" TextWrapping="Wrap">
                                    💡 Eye care reminders only appear during active focus sessions, not during breaks. Adjust the interval in Settings.
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Page 4: Statistics & Getting Started -->
                <StackPanel x:Name="Page4" Visibility="Collapsed">
                    <TextBlock Text="📊" FontSize="42" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Text="Track Your Progress" FontSize="24" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>

                    <Border Background="#1E1E2E" CornerRadius="12" Padding="24,18" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock Text="Statistics Dashboard:" Foreground="#F59E0B"
                                       FontSize="15" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,3">
                                📈  View daily and weekly focus time with bar charts.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,3">
                                🔥  Build a focus streak by completing at least one session every day.
                            </TextBlock>
                            <TextBlock Foreground="#D1D5DB" FontSize="14" TextWrapping="Wrap" Margin="0,3">
                                🏆  Track total sessions, completion rate, and focus minutes.
                            </TextBlock>

                            <Separator Background="#374151" Margin="0,14"/>

                            <TextBlock Text="You're all set!" Foreground="#10B981" FontSize="16"
                                       FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,10,0,6"/>
                            <TextBlock Foreground="#9CA3AF" FontSize="14" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" TextAlignment="Center">
                                Click "Get Started" to begin your first focus session. Reopen this guide anytime from the sidebar.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Navigation Footer -->
        <Border Grid.Row="1" Background="#0F172A" Padding="30,14">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="#6366F1" Margin="4,0"/>
                    <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="#374151" Margin="4,0"/>
                    <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="#374151" Margin="4,0"/>
                    <Ellipse x:Name="Dot4" Width="8" Height="8" Fill="#374151" Margin="4,0"/>
                </StackPanel>

                <Button x:Name="BackButton" HorizontalAlignment="Left" Click="OnBack"
                        Cursor="Hand" Visibility="Collapsed">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#374151" CornerRadius="8" Padding="20,10"
                                    x:Name="border" Cursor="Hand">
                                <TextBlock Text="← Back" Foreground="#D1D5DB" FontSize="14"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#4B5563"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="NextButton" HorizontalAlignment="Right" Click="OnNext" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#6366F1" CornerRadius="8" Padding="24,10"
                                    x:Name="border" Cursor="Hand">
                                <TextBlock x:Name="NextText" Text="Next →" Foreground="White"
                                           FontSize="14" FontWeight="SemiBold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#818CF8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
